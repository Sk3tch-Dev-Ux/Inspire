# Database
DATABASE_URL=postgresql://inspire:inspire@postgres:5432/inspire

# Stripe (Live)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Resend (Email)
RESEND_API_KEY=re_...

# Admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# Site
NEXT_PUBLIC_SITE_URL=https://inspirepc.com
NEXT_PUBLIC_APP_URL=https://inspirepc.com

# User Auth (OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
USER_JWT_SECRET=generate-a-random-64-character-string

# AI Chat
ANTHROPIC_API_KEY=

# ─── Discord Bot ───────────────────────────────────────────────
# Toggle the bot on. When false, /api/discord/* endpoints return 503.
DISCORD_BOT_ENABLED=false

# From discord.com/developers → Application
DISCORD_APP_ID=
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_FOUNDER_USER_ID=

# Roles (populated by scripts/discord-bootstrap-server.ts)
DISCORD_ROLE_ACTIVE_CLIENT=
DISCORD_ROLE_ALUMNI_CLIENT=
DISCORD_ROLE_PATRON=
DISCORD_ROLE_TRUSTED_BUILDER=

# Channels & categories (populated by scripts/discord-bootstrap-server.ts)
DISCORD_CATEGORY_PROJECTS=
DISCORD_CATEGORY_ARCHIVED=
DISCORD_CHANNEL_ACTIVE_PROJECTS=
DISCORD_CHANNEL_SHIPPED=
DISCORD_CHANNEL_LEADS=
DISCORD_CHANNEL_AVAILABILITY=
DISCORD_AVAILABILITY_MESSAGE_ID=
DISCORD_FORUM_QUOTES=

# Optional GitHub release → #shipped cross-post
GITHUB_WEBHOOK_SECRET=

# Cron tick interval (default 60s)
DELAYED_JOB_POLL_INTERVAL_MS=60000
